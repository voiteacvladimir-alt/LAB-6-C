#include <stdio.h>
#include <stdlib.h>
#include <time.h>

long long comparatii = 0;
long long schimbari = 0;

/* Functie pentru afisarea tabloului */
void afisareTablou(int a[], int n)
{
    int i;

    for(i = 0; i < n; i++)
    {
        printf("%d ", a[i]);
    }

    printf("\n");
}

/* Generare tablou aleatoriu */
void generareAleator(int a[], int n)
{
    int i;

    for(i = 0; i < n; i++)
    {
        a[i] = rand() % 100000;
    }
}

/* Generare tablou crescator */
void generareCrescator(int a[], int n)
{
    int i;

    for(i = 0; i < n; i++)
    {
        a[i] = i;
    }
}

/* Generare tablou descrescator */
void generareDescrescator(int a[], int n)
{
    int i;

    for(i = 0; i < n; i++)
    {
        a[i] = n - i;
    }
}

/* Selection Sort */
void selectionSort(int a[], int n)
{
    int i, j, minIndex, temp;

    comparatii = 0;
    schimbari = 0;

    for(i = 0; i < n - 1; i++)
    {
        minIndex = i;

        for(j = i + 1; j < n; j++)
        {
            comparatii++;

            if(a[j] < a[minIndex])
            {
                minIndex = j;
            }
        }

        if(minIndex != i)
        {
            temp = a[i];
            a[i] = a[minIndex];
            a[minIndex] = temp;

            schimbari++;
        }
    }
}

/* Functie pentru qsort */
int compara(const void *a, const void *b)
{
    return (*(int*)a - *(int*)b);
}

/* Analiza pentru Selection Sort */
void analizaSelection(int a[], int n)
{
    clock_t start, finish;
    double timp;

    start = clock();

    selectionSort(a, n);

    finish = clock();

    timp = (double)(finish - start) / CLOCKS_PER_SEC;

    printf("\n--- Selection Sort ---\n");
    printf("Numar comparatii: %lld\n", comparatii);
    printf("Numar schimbari: %lld\n", schimbari);
    printf("Timp executie: %.6f secunde\n", timp);
}

/* Analiza pentru qsort */
void analizaQsort(int a[], int n)
{
    clock_t start, finish;
    double timp;

    start = clock();

    qsort(a, n, sizeof(int), compara);

    finish = clock();

    timp = (double)(finish - start) / CLOCKS_PER_SEC;

    printf("\n--- qsort() ---\n");
    printf("Timp executie: %.6f secunde\n", timp);
}

